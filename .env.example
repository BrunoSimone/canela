# Frontend variables. Copy this file to .env.local for development.
# NEXT_PUBLIC_* vars are exposed to the browser.

# --- Site ---
# Public site URL (canonical, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number, international format without "+" (e.g. 5491155551234).
NEXT_PUBLIC_WHATSAPP_NUMBER=5491155551234

# --- Sanity (product CMS) ---
# projectId/dataset are public and live in src/sanity/env.ts (not env vars),
# because the Studio bundle only reads SANITY_STUDIO_* variables.
